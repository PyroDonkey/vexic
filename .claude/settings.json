{
  "autoMemoryEnabled": false,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "uv run python .claude/hooks/check_write_target.py",
            "timeout": 15,
            "statusMessage": "Checking write target against memory invariants"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run python .claude/hooks/check_branch_sync.py",
            "timeout": 60,
            "statusMessage": "Checking branch sync with origin"
          },
          {
            "type": "command",
            "command": "uv run python .claude/hooks/check_doc_drift.py",
            "timeout": 30,
            "statusMessage": "Checking in-repo doc drift"
          }
        ]
      }
    ]
  }
}
